# ─────────────────────────────────────────────────────────────────────────────
# Hermes Agent — Required Environment Variables
#
# For local docker-compose use: copy this file to .env and fill in values.
# For production / CI:          inject these as container environment variables
#                               (docker run -e, Kubernetes Secret, etc.).
#
# NEVER commit populated values to source control.
# ─────────────────────────────────────────────────────────────────────────────

# =============================================================================
# LLM Provider — supply at least one API key.
# Hermes auto-detects the active provider from the keys present.
# =============================================================================

# OpenRouter — routes to Claude, GPT, Gemini, Llama, and many others.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic (Claude) — direct API access.
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# OpenAI (GPT) — direct API access.
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google AI Studio (Gemini).
# https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=

# Nous Portal — subscription-based, zero extra config.
# https://portal.nousresearch.com/
# NOUS_API_KEY=

# DeepSeek — direct API access.
# https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=

# Hugging Face Inference Providers.
# https://huggingface.co/settings/tokens  (requires "Inference Providers" scope)
# HF_TOKEN=

# =============================================================================
# Telegram Bot
# =============================================================================
# Create a bot via @BotFather (https://t.me/BotFather) to obtain the token.
# TELEGRAM_ALLOWED_USERS: comma-separated Telegram usernames (no @) or
#   numeric user IDs that are permitted to message the bot.
# TELEGRAM_HOME_CHANNEL: channel/chat ID used for proactive output (cron, etc.)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
# TELEGRAM_HOME_CHANNEL=
# TELEGRAM_HOME_CHANNEL_NAME=

# Webhook mode (optional — for cloud deployments behind a public HTTPS URL).
# Default is long polling; set TELEGRAM_WEBHOOK_URL to switch.
# TELEGRAM_WEBHOOK_URL=https://my-host.example.com/telegram
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_SECRET=

# =============================================================================
# Discord Bot
# =============================================================================
# Register an app at https://discord.com/developers/applications, add a Bot
# user, enable the "Message Content" and "Server Members" privileged intents,
# and copy the token.
# DISCORD_ALLOWED_USERS: comma-separated Discord user IDs (enable Developer
#   Mode in Discord → right-click your username → Copy User ID).
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
# DISCORD_HOME_CHANNEL=
# DISCORD_HOME_CHANNEL_NAME=

# =============================================================================
# Optional Tool API Keys
# =============================================================================

# Exa — AI-native web search (enhances the web toolset).
# https://exa.ai
# EXA_API_KEY=

# Firecrawl — web crawl and extraction.
# https://firecrawl.dev/
# FIRECRAWL_API_KEY=

# fal.ai — image generation (enables the image_gen toolset).
# https://fal.ai/
# FAL_KEY=

# ElevenLabs — high-quality TTS (optional; Edge TTS is free and built-in).
# https://elevenlabs.io/
# ELEVENLABS_API_KEY=

# Groq — free-tier Whisper STT for voice message transcription.
# https://console.groq.com/keys
# GROQ_API_KEY=

# =============================================================================
# Container User Mapping (optional — only needed with a persistent volume)
# =============================================================================
# Set to the UID/GID of the host user that owns the data volume so that
# files created inside the container remain readable on the host.
# Ephemeral deployments (no volume) do not need these.
# HERMES_UID=1000
# HERMES_GID=1000
